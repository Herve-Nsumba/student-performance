# ──────────────────────────────────────────────────────────
# Student Performance ML System — Docker Environment
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=student_performance_db
POSTGRES_USER=student_user
POSTGRES_PASSWORD=student_pass

# ── Django ────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173

# ── ML Service (used internally by Django) ────────────────
ML_SERVICE_URL=http://ml_service:8001
